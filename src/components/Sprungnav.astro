---
/**
 * Sprungnavigation für lange Unterseiten (FAQ, Auszahlungstermine, …).
 * Rendert eine Chip-Liste, die zu den Abschnitts-Überschriften (h2 mit id)
 * springt. Wiederverwendbar — die Abschnitte werden als `items` übergeben.
 */
type SprungItem = { id: string; label: string };

interface Props {
  items: SprungItem[];
  titel?: string;
}

const { items, titel = 'Auf dieser Seite' } = Astro.props;
---

<nav class="sprungnav" aria-label="Sprungnavigation">
  <span class="sprungnav__titel">{titel}</span>
  <ul class="sprungnav__list" role="list">
    {items.map((item) => (
      <li>
        <a href={`#${item.id}`}>{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .sprungnav {
    background: var(--color-grey-50);
    border: 1px solid var(--color-grey-100);
    border-radius: 12px;
    padding: 16px 18px;
  }
  .sprungnav__titel {
    display: block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-grey-400);
    margin: 0 0 10px;
  }
  .sprungnav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sprungnav__list a {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary-700);
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-100);
    padding: 6px 12px;
    border-radius: 99px;
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .sprungnav__list a:hover {
    background: var(--color-primary-100);
    border-color: var(--color-primary-200);
  }
</style>
