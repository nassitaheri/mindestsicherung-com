---
import Layout from '../layouts/Layout.astro';

const title = 'Impressum | mindestsicherung.com';
const description = 'Impressum und Offenlegung nach §5 ECG (E-Commerce-Gesetz).';
---

<Layout title={title} description={description} path="/impressum/">
  <section class="container legal">
    <h1>Impressum</h1>
    <p class="legal__intro">Angaben gemäß § 5 ECG (E-Commerce-Gesetz)</p>

    <h2>Medieninhaber &amp; inhaltlich Verantwortlicher</h2>
    <p>
      Amir Taheri<br />
      Magdalenenstraße 3–7/1/15<br />
      1060 Wien, Österreich
    </p>

    <h2>Kontakt</h2>
    <p>
      E-Mail:
      <a href="mailto:kontakt@mindestsicherung.com">kontakt@mindestsicherung.com</a>
    </p>

    <h2>Haftungsausschluss</h2>
    <p>
      Die Inhalte dieser Website dienen ausschließlich der allgemeinen Information.
      Sie stellen keine Rechts-, Sozial- oder Steuerberatung dar. Für die
      Richtigkeit, Vollständigkeit und Aktualität der Inhalte wird keine Gewähr
      übernommen. Maßgeblich sind stets die zuständigen Behörden und Stellen des
      jeweiligen Bundeslandes.
    </p>

    <h2>Urheberrecht</h2>
    <p>
      Die auf dieser Website veröffentlichten Inhalte unterliegen dem
      österreichischen Urheberrecht.
    </p>

    <h2>Online-Streitbeilegung</h2>
    <p>
      Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung
      bereit:
      <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">
        https://ec.europa.eu/consumers/odr
      </a>
    </p>
  </section>

  <style>
    .legal {
      padding-top: clamp(32px, 6vw, 64px);
      padding-bottom: 64px;
    }
    .legal h1 {
      font-size: clamp(28px, 5vw, 40px);
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--color-grey-900);
      margin: 0 0 8px;
    }
    .legal__intro {
      font-size: 14px;
      color: var(--color-grey-400);
      margin: 0 0 40px;
    }
    .legal h2 {
      font-size: 16px;
      font-weight: 600;
      color: var(--color-grey-800);
      margin: 36px 0 8px;
    }
    .legal p {
      font-size: 15px;
      color: var(--color-grey-600);
      line-height: 1.6;
      max-width: 60ch;
      margin: 0;
    }
    .legal a {
      color: var(--color-primary-600);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  </style>
</Layout>
